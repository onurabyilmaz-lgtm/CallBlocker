<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/colorBackground">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Cagri Engelleyici"
            android:textSize="26sp"
            android:textStyle="bold"
            android:textColor="@color/colorPrimary"
            android:gravity="center"
            android:layout_marginBottom="8dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Gelen aramalari otomatik reddet ve mesaj gonder"
            android:textSize="14sp"
            android:textColor="#888888"
            android:gravity="center"
            android:layout_marginBottom="24dp" />

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="4dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Aramayi Engelle"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:textColor="@color/colorText" />

                    <Switch
                        android:id="@+id/switchMaster"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:scaleX="1.3"
                        android:scaleY="1.3" />
                </LinearLayout>

                <TextView
                    android:id="@+id/tvStatus"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Pasif - Aramalar normal"
                    android:textSize="15sp"
                    android:layout_marginTop="12dp"
                    android:padding="10dp"
                    android:background="@drawable/rounded_status"
                    android:gravity="center" />

                <TextView
                    android:id="@+id/tvActiveMode"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Mod: -"
                    android:textSize="13sp"
                    android:textColor="#888888"
                    android:layout_marginTop="8dp"
                    android:gravity="center" />

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="2dp">

            <Button
                android:id="@+id/btnManageContacts"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:text="Kisi Listesi Yonet"
                android:textSize="16sp"
                android:background="@drawable/btn_primary"
                android:textColor="#FFFFFF" />
        </androidx.cardview.widget.CardView>

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="2dp">

            <Button
                android:id="@+id/btnSchedule"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:text="Saat Ayarlari"
                android:textSize="16sp"
                android:background="@drawable/btn_secondary"
                android:textColor="#FFFFFF" />
        </androidx.cardview.widget.CardView>

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="2dp">

            <Button
                android:id="@+id/btnWhatsAppPermission"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:text="WhatsApp Izni Ver"
                android:textSize="16sp"
                android:background="@drawable/btn_warning"
                android:textColor="#FFFFFF" />
        </androidx.cardview.widget.CardView>

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="2dp">

            <Button
                android:id="@+id/btnXiaomiSetup"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:text="Xiaomi Ayarlari"
                android:textSize="16sp"
                android:background="@drawable/btn_outline"
                android:textColor="@color/colorPrimary" />
        </androidx.cardview.widget.CardView>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Aktif durumdayken bildirim cubugunda kucuk bir ikon gorunur."
            android:textSize="12sp"
            android:textColor="#AAAAAA"
            android:layout_marginTop="16dp"
            android:gravity="center"
            android:lineSpacingExtra="4dp" />

    </LinearLayout>
</ScrollView>
