<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/colorBackground">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="3dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Tum Aramalari Engelle"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            android:textColor="@color/colorText" />

                        <Switch
                            android:id="@+id/switchBlockAll"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content" />
                    </LinearLayout>

                    <TextView
                        android:id="@+id/tvContactHint"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Sadece listedeki kisilerin aramalari engellenecek"
                        android:textSize="13sp"
                        android:textColor="#888888"
                        android:layout_marginTop="6dp" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="3dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Varsayilan Otomatik Mesaj"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:textColor="@color/colorText"
                        android:layout_marginBottom="8dp" />

                    <EditText
                        android:id="@+id/etDefaultMessage"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="Arayan kisiye gonderilecek mesaj..."
                        android:minLines="2"
                        android:maxLines="4"
                        android:padding="10dp"
                        android:background="@drawable/rounded_edittext"
                        android:textSize="14sp" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Engellenen Kisiler"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="@color/colorText"
                android:layout_marginBottom="8dp"
                android:layout_marginTop="4dp" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/recyclerContacts"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:nestedScrollingEnabled="false" />

        </LinearLayout>
    </ScrollView>

    <Button
        android:id="@+id/btnAddContact"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:text="+ Kisi Ekle"
        android:textSize="16sp"
        android:textColor="#FFFFFF"
        android:background="@drawable/btn_primary"
        android:layout_margin="16dp" />

</LinearLayout>
